{
  "name": "mdchirp",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first rich editor & publisher for Jekyll Chirpy blogs",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter '!@mdchirp/desktop' build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r --if-present test",
    "test:integration": "tsx packages/core/src/sync/sync.itest.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "dev:backend": "pnpm --filter @mdchirp/backend dev",
    "dev:playground": "pnpm --filter @mdchirp/playground dev",
    "dev:desktop": "pnpm --filter @mdchirp/desktop dev"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "prettier": "^3.3.0",
    "eslint": "^9.13.0",
    "@eslint/js": "^9.13.0",
    "typescript-eslint": "^8.11.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-config-prettier": "^9.1.0"
  },
  "packageManager": "pnpm@9.15.9"
}
